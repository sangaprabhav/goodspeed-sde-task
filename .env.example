# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URLs
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3001

# OpenRouter (recommended: one key for chat + embeddings)
# Paste your key here:
OPENROUTER_API_KEY=sk-or-your-key-here

# Chat (swap axis 1): defaults work with OpenRouter when OPENROUTER_API_KEY is set
AI_CHAT_PROVIDER=openai-compatible
AI_CHAT_BASE_URL=https://openrouter.ai/api/v1
AI_CHAT_API_KEY=
AI_CHAT_MODEL=openai/gpt-4o-mini

# Embeddings (swap axis 2): uses OPENROUTER_API_KEY if AI_EMBEDDING_API_KEY is empty
# IMPORTANT: Changing embedding model requires POST /documents/reindex
AI_EMBEDDING_PROVIDER=openai-compatible
AI_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_MODEL=openai/text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536

# Alternative: OpenAI direct (uncomment and set AI_CHAT_API_KEY instead)
# AI_CHAT_BASE_URL=https://api.openai.com/v1
# AI_CHAT_API_KEY=sk-...
# AI_CHAT_MODEL=gpt-4o-mini
# AI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# AI_EMBEDDING_API_KEY=sk-...
# AI_EMBEDDING_MODEL=text-embedding-3-small

# RAG tuning
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.2
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
DB_VECTOR_DIMENSIONS=1536
