{
  "name": "goodspeed-knowledge-base",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "setup": "pnpm install && pnpm exec playwright install chromium && node scripts/setup.mjs",
    "dev": "turbo dev",
